# Frontend only — Variables accessibles dans le code Vue via import.meta.env.VITE_*

# Clé publique reCAPTCHA v3 (obtenir sur https://www.google.com/recaptcha/admin)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# URL du backend déployé (ex: https://glamour-chic-backend.onrender.com)
# Laisser vide en développement local (le proxy Vite gère /api → localhost:3001)
VITE_API_URL=
