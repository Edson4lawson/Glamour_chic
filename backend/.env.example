# Backend — Variables d'environnement (NE PAS COMMITTER CE FICHIER)
# Copier ce fichier en .env et remplir les valeurs réelles

# Port d'écoute (Render injecte automatiquement la bonne valeur)
PORT=3001

# URL exacte du frontend déployé sur Vercel (pour CORS)
FRONTEND_ORIGIN=https://votre-projet.vercel.app

# reCAPTCHA v3 — clé SECRÈTE (obtenir sur https://www.google.com/recaptcha/admin)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
RECAPTCHA_ACTION=contact
RECAPTCHA_SCORE_THRESHOLD=0.5

# SendGrid — clé API (obtenir sur https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Adresses email
CONTACT_TO_EMAIL=Glamour19chic@gmail.com
CONTACT_FROM_EMAIL=Glamour19chic@gmail.com
